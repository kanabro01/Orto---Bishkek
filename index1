            align-items: center;
            gap: 10px;
        }

        .about-list i {
            color: #0f7b6e;
        }

        .about-img {
            flex: 1;
            background: #eaf3f0;
            border-radius: 32px;
            padding: 20px;
            text-align: center;
        }

        /* footer */
        .footer {
            background: #0b2b2e;
            color: #d9eae7;
            padding: 48px 0 24px;
            margin-top: 70px;
            border-radius: 40px 40px 0 0;
