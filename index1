<!-- Modal -->
<div id="callbackModal" class="modal">
    <div class="modal-content">
        <span class="close-modal">&times;</span>
        <h3>Оставьте заявку</h3>
        <p>Наш специалист свяжется с вами для подбора корсета и уточнения деталей.</p>
        <form id="callbackForm">
            <div class="form-group"><input type="text" placeholder="Ваше имя" required id="nameInput"></div>
            <div class="form-group"><input type="tel" placeholder="Телефон / WhatsApp" required id="phoneInput"></div>
            <div class="form-group"><textarea rows="2" placeholder="Комментарий (модель, вопрос)"></textarea></div>
            <button type="submit" class="btn-primary" style="width:100%">Отправить</button>
        </form>
    </div>
</div>

<script>
    // модальное окно
    const modal = document.getElementById('callbackModal');
    const openBtns = document.querySelectorAll('#openModalBtn, #heroOrderBtn, #aboutContactBtn');
    const closeModalBtn = document.querySelector('.close-modal');
    const orderProductBtns = document.querySelectorAll('.order-product');

    function openModal(productName = '') {
        modal.style.display = 'flex';
        if (productName) {
            const textarea = modal.querySelector('textarea');
            if (textarea) textarea.value = `Интересует товар: ${productName}`;
        }
    }
    openBtns.forEach(btn => btn.addEventListener('click', () => openModal()));
    orderProductBtns.forEach(btn => {
        btn.addEventListener('click', (e) => {
            const product = btn.getAttribute('data-name');
            openModal(product);
        });
    });
    closeModalBtn.addEventListener('click', () => modal.style.display = 'none');
    window.addEventListener('click', (e) => { if (e.target === modal) modal.style.display = 'none'; });
    
    // форма имитация отправки
    const form = document.getElementById('callbackForm');
    form.addEventListener('submit', (e) => {
        e.preventDefault();
        alert('Спасибо! Мы свяжемся с вами в ближайшее время. (тестовый режим)');
        modal.style.display = 'none';
        form.reset();
    });
    
    // плавный скролл для навигации
    document.querySelectorAll('.nav-links a, .btn-primary[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', function(e) {
            const hash = this.getAttribute('href');
            if (hash && hash.startsWith('#')) {
                e.preventDefault();
                const target = document.querySelector(hash);
                if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }
        });
    });
    // также обработка для контактной кнопки в about
    document.querySelector('#aboutContactBtn')?.addEventListener('click', () => openModal());
    // маленький фикс для подменю
    const heroOrderBtn = document.getElementById('heroOrderBtn');
    if(heroOrderBtn) heroOrderBtn.addEventListener('click', () => openModal());
    
    // отображение номера телефона в ватсап
    console.log('Коммерческий сайт Orto-Bishkek успешно загружен');
</script>
</body>
</html>
