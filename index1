<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Orto-Bishkek | Медицинские ортопедические корсеты в Кыргызстане</title>
    <!-- Font Awesome 6 (free) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <!-- Google Fonts: Inter & Playfair Display -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&family=Playfair+Display:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: #ffffff;
            color: #1e2a3e;
            line-height: 1.4;
            scroll-behavior: smooth;
        }

        .container {
            max-width: 1280px;
            margin: 0 auto;
            padding: 0 24px;
        }

        /* header / nav */
        .navbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 0;
            flex-wrap: wrap;
            gap: 20px;
        }

        .logo h1 {
            font-family: 'Playfair Display', serif;
            font-size: 1.8rem;
            font-weight: 700;
            color: #0b3b3f;
            letter-spacing: -0.3px;
        }

        .logo p {
            font-size: 0.75rem;
            color: #2c6e6b;
            font-weight: 500;
            letter-spacing: 0.5px;
        }

        .nav-links {
            display: flex;
            gap: 32px;
            list-style: none;
        }

        .nav-links a {
            text-decoration: none;
            font-weight: 500;
            color: #1e3a3f;
            transition: color 0.2s;
            font-size: 1rem;
        }

        .nav-links a:hover {
            color: #0f7b6e;
        }

        .btn-outline {
            border: 1.5px solid #0f7b6e;
            background: transparent;
            padding: 8px 20px;
            border-radius: 40px;
            font-weight: 600;
            color: #0f7b6e;
            transition: 0.2s;
            cursor: pointer;
            font-size: 0.9rem;
        }

        .btn-outline:hover {
            background: #0f7b6e;
            color: white;
        }

        .btn-primary {
            background: #0f7b6e;
            border: none;
            padding: 12px 28px;
            border-radius: 40px;
            font-weight: 600;
            color: white;
            cursor: pointer;
            transition: 0.2s;
            font-size: 1rem;
            display: inline-flex;
            align-items: center;
            gap: 10px;
        }

        .btn-primary:hover {
            background: #0a5f55;
            transform: translateY(-2px);
        }

        /* hero */
        .hero {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            justify-content: space-between;
            gap: 40px;
            margin: 40px 0 60px;
        }

        .hero-content {
            flex: 1;
        }

        .hero-badge {
            background: #e6f7f4;
            color: #0f7b6e;
            display: inline-block;
            padding: 6px 14px;
            border-radius: 40px;
            font-size: 0.8rem;
            font-weight: 600;
            margin-bottom: 20px;
        }

        .hero-content h1 {
            font-size: 3rem;
            font-weight: 700;
            line-height: 1.2;
            color: #0b2b2e;
            margin-bottom: 20px;
        }

        .hero-content p {
            font-size: 1.1rem;
            color: #2d4a53;
            margin-bottom: 30px;
            max-width: 90%;
        }

        .hero-stats {
            display: flex;
            gap: 30px;
            margin-top: 20px;
        }

        .stat-item {
            font-weight: 700;
        }

        .stat-number {
            font-size: 1.8rem;
            color: #0f7b6e;
        }

        .hero-img {
            flex: 1;
            background: #eef9f6;
            border-radius: 32px;
            padding: 20px;
            text-align: center;
        }

        .hero-img img {
            max-width: 100%;
            border-radius: 24px;
            width: 100%;
            object-fit: cover;
            aspect-ratio: 1 / 0.9;
        }

        /* products grid */
        .section-title {
            text-align: center;
            font-size: 2.2rem;
            font-weight: 700;
            margin-bottom: 16px;
            color: #0b3b3f;
        }

        .section-sub {
            text-align: center;
            color: #4a6772;
            max-width: 700px;
            margin: 0 auto 48px;
        }

        .products-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
            gap: 30px;
            margin: 40px 0;
        }

        .product-card {
            background: #ffffff;
            border-radius: 28px;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.03);
            border: 1px solid #e2efec;
            padding: 24px 20px;
            transition: all 0.25s ease;
            text-align: center;
        }

        .product-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 20px 30px -12px rgba(15, 123, 110, 0.15);
            border-color: #c0dfd9;
        }

        .product-icon {
            font-size: 2.7rem;
            color: #0f7b6e;
            margin-bottom: 20px;
        }

        .product-card h3 {
            font-size: 1.4rem;
            margin-bottom: 12px;
        }

        .product-price {
            font-weight: 700;
            font-size: 1.3rem;
            color: #1f5e58;
            margin: 12px 0;
        }

        .product-desc {
            color: #42636e;
            font-size: 0.9rem;
            margin-bottom: 18px;
        }

        /* преимущества */
        .advantages {
            background: #f8fefc;
            border-radius: 48px;
            padding: 60px 40px;
            margin: 70px 0;
        }

        .adv-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 32px;
            margin-top: 40px;
        }

        .adv-item {
            text-align: center;
        }

        .adv-icon {
            font-size: 2.5rem;
            background: #e2f3ef;
            width: 70px;
            height: 70px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 30px;
            margin: 0 auto 20px;
            color: #0f7b6e;
        }

        /* about production */
        .about {
            display: flex;
            flex-wrap: wrap;
            gap: 40px;
            align-items: center;
            margin: 60px 0;
        }

        .about-text {
            flex: 1;
        }

        .about-text h2 {
            font-size: 1.8rem;
            margin-bottom: 20px;
        }

        .about-list {
            list-style: none;
            margin: 20px 0;
        }

        .about-list li {
            margin-bottom: 12px;
